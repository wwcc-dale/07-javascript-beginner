                <response_label ident="answer1">
                  <material>
                    <mattext texttype="text/plain">Functions reduce repetition, make code cleaner, and are easier to fix</mattext>
                  </material>
                </response_label>
                <response_label ident="answer2">
                  <material>
                    <mattext texttype="text/plain">Functions are required in JavaScript</mattext>
                  </material>
                </response_label>
                <response_label ident="answer3">
                  <material>
                    <mattext texttype="text/plain">Functions use less memory</mattext>
                  </material>

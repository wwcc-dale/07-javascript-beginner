          <presentation>
            <material>
              <mattext texttype="text/html">&lt;p&gt;What does this ensure? `class Game { constructor() { if (!this.validateBrowser()) throw new Error(&amp;#x27;Browser not supported&amp;#x27;); this.initialize(); } validateBrowser() { return &amp;#x27;localStorage&amp;#x27; in window &amp;amp;&amp;amp; &amp;#x27;Promise&amp;#x27; in window; } }`&lt;/p&gt;</mattext>
            </material>
            <response_lid ident="response1" rcardinality="Single">
              <render_choice>
                <response_label ident="answer0">
                  <material>
                    <mattext texttype="text/plain">Checks browser supports required features before starting game</mattext>
                  </material>
                </response_label>
                <response_label ident="answer1">
                  <material>
                    <mattext texttype="text/plain">Always throws error</mattext>
                  </material>
                </response_label>
                <response_label ident="answer2">
                  <material>
                    <mattext texttype="text/plain">Does nothing</mattext>
                  </material>
                </response_label>
                <response_label ident="answer3">
                  <material>
                    <mattext texttype="text/plain">Only checks localStorage</mattext>
                  </material>
                </response_label>
              </render_choice>
            </response_lid>
          </presentation>
          <resprocessing>
            <outcomes>
              <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>

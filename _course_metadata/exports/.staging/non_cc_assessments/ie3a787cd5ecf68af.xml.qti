              <render_choice>
                <response_label ident="answer0">
                  <material>
                    <mattext texttype="text/plain">Use class: `class Game { constructor() { this.deck = new Deck(); this.player1 = new Player(); this.player2 = new Player(); } start() { this.deck.shuffle(); this.dealCards(); } }`</mattext>
                  </material>
                </response_label>
                <response_label ident="answer1">
                  <material>
                    <mattext texttype="text/plain">Code is perfect</mattext>

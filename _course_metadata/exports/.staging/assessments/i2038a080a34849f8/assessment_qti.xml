    <objectives>
      <material>
        <mattext texttype="text/html">&lt;h1&gt;Session 15 Quiz – Event Handling and Forms&lt;/h1&gt;
&lt;p&gt;Test your understanding of event listeners, event objects, and form handling.&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Topics Covered:&lt;/strong&gt;
- addEventListener and event types
- preventDefault and stopPropagation
- Event bubbling and delegation
- Form validation
- this binding in event handlers&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Instructions:&lt;/strong&gt;
- 16 questions from the Session 15 question bank
- 20 minute time limit
- 3 attempts allowed
- 16 points total (1 point per question)&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;After syncing the question bank to Canvas:&lt;/strong&gt;&lt;/p&gt;</mattext>
      </material>
    </objectives>
    <section ident="i2038a080a34849f8_section">
      <item ident="i2038a080a34849f8_q1" title="Question 1">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>cc_weighting</fieldlabel>
              <fieldentry>1.0</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;What does this do? `button.addEventListener(&amp;#x27;click&amp;#x27;, () =&amp;gt; console.log(&amp;#x27;Clicked&amp;#x27;));`&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="answer0">
                <material>
                  <mattext texttype="text/plain">Logs 'Clicked' every time button is clicked</mattext>
                </material>
              </response_label>
              <response_label ident="answer1">
                <material>
                  <mattext texttype="text/plain">Logs 'Clicked' once then stops</mattext>
                </material>
              </response_label>
              <response_label ident="answer2">
                <material>
                  <mattext texttype="text/plain">Error thrown</mattext>
                </material>
              </response_label>
              <response_label ident="answer3">
                <material>
                  <mattext texttype="text/plain">Nothing happens</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">answer0</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
